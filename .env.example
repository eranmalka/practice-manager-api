# Database (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/practice_manager

# API
PORT=3000
JWT_SECRET=change-me-in-production

# CORS: comma-separated origins for the SPA (production: your real origin)
CORS_ORIGIN=http://localhost:4200

# SPA base URL — OAuth success/failure redirects are built from this
FRONTEND_URL=http://localhost:4200

# Google OAuth (Web application client in Google Cloud Console)
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly (API host, not :4200).
# Use http://localhost:3000 (not 127.0.0.1) unless you register 127.0.0.1 in Console too.
# Also add Authorized JavaScript origin: http://localhost:3000 if Google asks.
# Do not open /auth/google/callback directly — start from /auth/google (SPA or browser).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Facebook Login (Meta Developers)
# Valid OAuth Redirect URI must match FACEBOOK_CALLBACK_URL
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback
