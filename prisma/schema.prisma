// schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Song {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  title     String
  artist    String?
  composer  String?
  key       String?
  bpm       Int?
  genre     String?
  difficulty String?
  status    String   @default("want_to_learn")
  lyrics    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String?
  createdAt    DateTime @default(now())
  songs Song[]
}