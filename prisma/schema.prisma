// schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SongStatus {
  want_to_learn
  learning
  in_rotation
  performance_ready
}

enum ChordChartFormat {
  chordpro
  ireal
  plain
}

model Song {
  id                     String   @id @default(uuid())
  userId                 Int
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title                  String
  artist                 String?
  status                 SongStatus @default(want_to_learn)
  backingTrackUrl        String?
  musicBrainzRecordingId String?
  sheetMusicUrl          String?
  chordChartRaw          String?  @db.Text
  chordChartFormat      ChordChartFormat?
  chordChartKey         String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId])
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  instrument   String?
  passwordHash String?
  googleId     String?  @unique
  facebookId   String?  @unique
  createdAt    DateTime @default(now())
  songs        Song[]
}
