{
  "info": {
    "name": "Practice Musician Hub",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API collection for Practice Musician Hub backend"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "song_id",
      "value": "",
      "type": "string",
      "description": "UUID from Create song response (paste here for Get/Update/Delete by id)"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (create user)",
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eran@example.com\",\n  \"name\": \"Eran\",\n  \"password\": \"12345678\",\n  \"instrument\": \"Guitar\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.access_token) {",
                  "    pm.collectionVariables.set('token', res.access_token);",
                  "    console.log('Token saved!');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "auth": { "type": "noauth" },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"eran@example.com\",\n  \"password\": \"12345678\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get my profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": ["{{base_url}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "Update my profile",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Eran Malka\",\n  \"instrument\": \"Piano\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": ["{{base_url}}"],
              "path": ["users", "me"]
            }
          }
        },
        {
          "name": "Get all users",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get user by ID",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/users/1",
              "host": ["{{base_url}}"],
              "path": ["users", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Music",
      "item": [
        {
          "name": "Search (MusicBrainz)",
          "request": {
            "method": "GET",
            "header": [],
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{base_url}}/music/search?title=Human%20Nature&artist=Michael%20Jackson",
              "host": ["{{base_url}}"],
              "path": ["music", "search"],
              "query": [
                { "key": "title", "value": "Human Nature" },
                { "key": "artist", "value": "Michael Jackson" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Repertoire",
      "item": [
        {
          "name": "Get all my songs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/repertoire/songs",
              "host": ["{{base_url}}"],
              "path": ["repertoire", "songs"]
            }
          }
        },
        {
          "name": "Get song by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/repertoire/songs/{{song_id}}",
              "host": ["{{base_url}}"],
              "path": ["repertoire", "songs", "{{song_id}}"]
            }
          }
        },
        {
          "name": "Create song",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Autumn Leaves\",\n  \"artist\": \"Joseph Kosma\",\n  \"status\": \"want_to_learn\",\n  \"musicBrainzRecordingId\": null,\n  \"sheetMusicUrl\": null,\n  \"backingTrackUrl\": null,\n  \"chordChartRaw\": null,\n  \"chordChartFormat\": null,\n  \"chordChartKey\": \"G\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/repertoire/songs",
              "host": ["{{base_url}}"],
              "path": ["repertoire", "songs"]
            }
          }
        },
        {
          "name": "Update song",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"learning\",\n  \"chordChartRaw\": \"[C] Autumn [Am] leaves\",\n  \"chordChartFormat\": \"plain\",\n  \"chordChartKey\": \"G\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/repertoire/songs/{{song_id}}",
              "host": ["{{base_url}}"],
              "path": ["repertoire", "songs", "{{song_id}}"]
            }
          }
        },
        {
          "name": "Delete song",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/repertoire/songs/{{song_id}}",
              "host": ["{{base_url}}"],
              "path": ["repertoire", "songs", "{{song_id}}"]
            }
          }
        }
      ]
    }
  ]
}
